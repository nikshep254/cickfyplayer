# Cricfy Web — Environment Variables
# Copy this to .env.local for development
# Add all these as Vercel environment variables for production

# AES decryption keys from the Kodi plugin's secret1.txt and secret2.txt
# Format: hex_key:hex_iv (colon-separated hex strings)
SECRET1=your_hex_key_here:your_hex_iv_here
SECRET2=your_hex_key_here:your_hex_iv_here

# Firebase credentials — extract from the Cricfy Android APK
# or from the plugin's cricfy_properties.json (add it to resources/ after extracting from APK)
CRICFY_PACKAGE_NAME=your.cricfy.package.name
CRICFY_FIREBASE_API_KEY=AIzaSy...
CRICFY_FIREBASE_APP_ID=1:123456789:android:abc123
